{
  "name": "sbm",
  "private": true,
  "version": "12.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,jsx}",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "test": "node tests/logic-tests.mjs && node tests/schema-tests.mjs && node tests/integration-tests.mjs && node tests/sync-tests.mjs && node scripts/check-rules-sync.mjs",
    "test:coverage": "c8 --reporter=text --reporter=html --include=src/logic.js -- node tests/logic-tests.mjs",
    "test:fuzz": "node tests/logic-fuzz.mjs",
    "test:mutation": "stryker run",
    "test:rules-sync": "node scripts/check-rules-sync.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"node tests/rules-tests.mjs\" --project demo-sbm-test",
    "test:sync-emulator": "firebase emulators:exec --only firestore \"node tests/sync-emulator-tests.mjs\" --project demo-sbm-test",
    "test:canary": "firebase emulators:exec --only firestore \"node tests/canary-tests.mjs\" --project demo-sbm-test",
    "emulators": "firebase emulators:start --only firestore,database --project demo-sbm-test",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^6.0.1",
    "@capacitor-mlkit/barcode-scanning": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.3",
    "@codetrix-studio/capacitor-google-auth": "3.3.6",
    "@e-is/capacitor-bluetooth-serial": "^6.0.3",
    "@hugotomazi/capacitor-navigation-bar": "^4.0.1",
    "firebase": "^12.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.10.4",
    "recharts": "^2.15.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/js": "^9.39.5",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@stryker-mutator/core": "^8.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "c8": "^10.1.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "^3.21.0",
    "firebase-tools": "^15.24.0",
    "globals": "^15.15.0",
    "husky": "^9.1.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.2"
  }
}
